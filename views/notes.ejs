<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Notes - NoteHub</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="nav-container">
            <h1>📝 NoteHub</h1>
            <div class="nav-links">
                <span>👤 <%= username %></span>
                <a href="/add-note">✍️ Add Note</a>
                <a href="/logout">🚪 Logout</a>
            </div>
        </div>
    </nav>

    <div class="container" style="margin-top:40px">
        <div class="section-header">        
            <h1>📚 Your Notes</h1>
            <p>All your notes in one place</p>
        </div>

        <div style="margin-bottom:24px; display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
            <a href="/add-note" class="button">✍️ Add New Note</a>
            <form action="/search" method="GET" style="display:flex; gap:8px; flex:1; min-width:200px;">
                <input type="text" name="q" placeholder="🔍 Search notes by title, content or tag..."
                    value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                    style="flex:1; padding:10px 16px; border:2px solid #e5e7eb; border-radius:8px; font-size:14px; outline:none; font-family:inherit;">
                <button type="submit" style="padding:10px 18px; background:linear-gradient(135deg,#2563eb,#3b82f6); color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Search</button>
                <% if(typeof searchQuery !== 'undefined' && searchQuery) { %>
                    <a href="/notes" style="padding:10px 14px; background:#f3f4f6; color:#6b7280; border-radius:8px; text-decoration:none; font-size:14px; font-weight:500; display:flex; align-items:center;">✕ Clear</a>
                <% } %>
            </form>
        </div>
        <% if(typeof searchQuery !== 'undefined' && searchQuery) { %>
            <div style="margin-bottom:16px; color:#6b7280; font-size:14px;">
                Showing results for <strong>"<%= searchQuery %>"</strong> — <%= notes.length %> note<%= notes.length !== 1 ? 's' : '' %> found
            </div>
        <% } %>


        <!-- Empty State -->
        <% if(notes.length === 0){ %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <h3>No Notes Yet</h3>
                <p>Start capturing your thoughts by creating your first note!</p>
                <a href="/add-note" class="button" style="margin-top:20px">
                    ✨ Create Your First Note
                </a>
            </div>
        <% } %>

        <div class="notes-grid">

    <% notes.forEach(note => { %>
    <%
    const formattedDate = new Date(note.createdAt).toLocaleDateString(
    'en-US',
    { year:'numeric', month:'short', day:'numeric'}
    )
    %>

        <div class="note">
            <a href="/note/<%= note._id %>" class="note-title">
                <h3><%= note.title %></h3>
            </a>
            <p class="note-preview">
                <%= note.content.replace(/<[^>]*>/g, '').substring(0,180) %>...
            </p>
                <button onclick="generateSummary('<%= note._id %>')">
                    Generate AI Summary
                </button>

            <!-- AI SUMMARY -->
            <% if(note.summary){ %>
                <div class="ai-box" id="summary-<%= note._id %>">   
                    <strong>🤖 AI Summary:</strong>
                    <p><%= note.summary %></p>
                </div>
            <% } else { %>
                <div class="ai-box muted" id="summary-<%= note._id %>">
                    <em>AI Summary not generated yet</em>
                </div>
            <% } %>

            <!-- TAGS -->
            <% if(note.tags.length > 0){ %>
                <div class="tags">
                    <% note.tags.forEach(tag => { %>
                        <span class="tag">#<%= tag %></span>
                    <% }) %>
                </div>
            <% } %>

            <div class="note-meta">
                <span>📅 <%= formattedDate %></span>
                <span>✏️ Created</span>
            </div>
            <div class="note-actions">
                <form action="/delete-note/<%= note._id %>" method="POST" style="display:inline">
                    <button type="submit" class="button-danger" onclick="return confirm('Are you sure you want to delete this note?')">
                        🗑️ Delete
                    </button>
                </form>
            </div>
        </div>
    <% }) %>
     </div>
    </div>

<script src="/js/script.js"></script>

<footer>
    <p>
        &copy; 2025 NoteHub. Built with ❤️ using Node.js, Express, and MongoDB
    </p>
</footer>


</body>
</html>